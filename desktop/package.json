{
  "name": "viperduel",
  "version": "1.0.0",
  "description": "ViperDuel — split-screen combined-arms combat",
  "author": "ViperShard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:win": "electron-builder --win nsis portable",
    "dist:mac": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.vipershard.viperduel",
    "productName": "ViperDuel",
    "files": ["main.js", "app/**/*"],
    "linux": { "target": ["AppImage"], "category": "Game", "artifactName": "ViperDuel-${version}.${ext}" },
    "win": { "target": ["nsis", "portable"] },
    "mac": { "target": ["dmg"], "category": "public.app-category.games" }
  }
}
